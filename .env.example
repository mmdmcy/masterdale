# Copy this file to .env in each device's Masterdale repo root.
# Keep .env private. It is intentionally ignored by git.

# Shared bearer token for fleet endpoints across your private network.
DALE_TOKEN=

# Set to 1 on devices where you explicitly want remote command execution.
# File list/read/search does not need this. Remote commands are powerful.
DALE_REMOTE_EXEC=0

# Scope for non-loopback clients:
# private = loopback + normal private LAN ranges + Tailscale (default)
# tailnet = loopback + Tailscale only
# loopback = local machine only
# public = any source IP; only use behind a firewall/reverse proxy
DALE_REMOTE_SCOPE=private

# Optional: where comdale/autodale should post events.
LEARDALE_URL=http://127.0.0.1:7345

# Optional: one warm all-round model for normal work. Use role strategy when
# you prefer task-specific models instead of keeping one model resident.
DALE_MODEL=gemma4:e2b
DALE_MODEL_STRATEGY=primary

# Optional: safe roots exposed by file/list/search APIs. Use your platform's
# path-list separator, e.g. ":" on Linux/macOS and ";" on Windows.
DALE_SAFE_ROOTS=

# Optional app/profile checks.
COMDALE_PROFILE=profiles/example-business.json

# Optional extra markdown files included in dashboard AI context.
# Use the platform path-list separator, e.g. ":" on Linux/macOS and ";" on Windows.
DALE_DASHBOARD_CONTEXT_DOCS=
